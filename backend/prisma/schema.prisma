generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model accounts {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  users             users   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model ai_usage_analytics {
  id                 String        @id @default(uuid())
  user_id            String
  action_type        String
  input_length       Int?
  output_length      Int?
  coins_spent        Int?
  processing_time_ms Int?
  created_at         DateTime      @default(now())
  user_profiles      user_profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([created_at(sort: Desc)])
  @@index([user_id])
}

model analytics {
  id         String   @id @default(uuid())
  user_id    String
  event_type String
  event_data Json     @default("{}")
  session_id String?
  created_at DateTime @default(now())
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([created_at(sort: Desc)])
  @@index([user_id])
}

model audit_logs {
  id            String   @id @default(uuid())
  user_id       String?
  action        String
  resource_type String?
  resource_id   String?
  ip_address    String?
  user_agent    String?
  metadata      Json     @default("{}")
  created_at    DateTime @default(now())
  users         users?   @relation(fields: [user_id], references: [id])
}

model coins_transactions {
  id               String        @id @default(uuid())
  user_id          String
  amount           Int
  transaction_type String
  action_type      String?
  description      String?
  created_at       DateTime      @default(now())
  user_profiles    user_profiles @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model document_approvals {
  id           String    @id @default(uuid())
  document_id  String    @unique
  team_id      String
  status       String    @default("draft")
  submitted_by String?
  submitted_at DateTime?
  reviewed_by  String?
  reviewed_at  DateTime?
  review_note  String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now())

  @@index([status])
  @@index([team_id])
}

model document_comments {
  id          String    @id @default(uuid())
  document_id String
  team_id     String
  user_id     String
  user_email  String
  user_name   String?
  content     String
  selection   Json?
  resolved    Boolean   @default(false)
  resolved_by String?
  resolved_at DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now())

  @@index([document_id])
  @@index([team_id])
}

model document_presence {
  id          String   @id @default(uuid())
  document_id String
  team_id     String
  user_id     String
  user_email  String
  user_name   String?
  cursor_pos  Int?
  last_seen   DateTime @default(now())

  @@unique([document_id, user_id])
  @@index([document_id])
}

model document_versions {
  id          String   @id @default(uuid())
  document_id String
  team_id     String
  user_id     String
  version_num Int
  title       String
  content     String
  change_note String?
  created_at  DateTime @default(now())

  @@index([document_id])
  @@index([team_id])
}

model documents {
  id             String         @id @default(uuid())
  user_id        String
  title          String         @default("Untitled Document")
  content        String         @default("")
  metadata       Json           @default("{}")
  is_public      Boolean        @default(false)
  last_synced_at DateTime?
  version        Int            @default(1)
  word_count     Int            @default(0)
  char_count     Int            @default(0)
  created_at     DateTime       @default(now())
  updated_at     DateTime       @default(now())
  users          users          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  revisions      revisions[]
  transactions   transactions[]

  @@index([updated_at(sort: Desc)])
  @@index([user_id])
}

model notifications {
  id         String   @id @default(uuid())
  user_id    String
  title      String
  message    String
  type       String   @default("info")
  read       Boolean  @default(false)
  created_at DateTime @default(now())
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([created_at(sort: Desc)])
}

model plagiarism_checks {
  id              String   @id @default(uuid())
  userId          String
  originalText    String
  similarityScore Float
  sources         Json     @default("[]")
  coinsUsed       Int      @default(30)
  createdAt       DateTime @default(now())
  users           users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model revisions {
  id          String    @id @default(uuid())
  document_id String
  user_id     String
  content     String
  intent      String?
  tone        String?
  tokens_used Int       @default(0)
  cost_usd    Decimal   @default(0) @db.Decimal(10, 6)
  model       String?
  metadata    Json      @default("{}")
  created_at  DateTime  @default(now())
  documents   documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([document_id])
  @@index([user_id])
}

model sessions {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  users        users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model subscriptions {
  id                     String    @id @default(uuid())
  user_id                String    @unique
  stripe_subscription_id String?   @unique
  stripe_customer_id     String?   @unique
  status                 String    @default("inactive")
  plan_name              String    @default("free")
  current_period_start   DateTime?
  current_period_end     DateTime?
  cancel_at_period_end   Boolean   @default(false)
  created_at             DateTime  @default(now())
  updated_at             DateTime  @default(now())
  users                  users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model team_content_library {
  id                                            String   @id @default(uuid())
  team_id                                       String
  created_by                                    String?
  title                                         String
  content                                       String
  category                                      String?
  tags                                          Json     @default("[]")
  usage_count                                   Int      @default(0)
  approved                                      Boolean  @default(false)
  approved_by                                   String?
  created_at                                    DateTime @default(now())
  approver                                      users?   @relation("team_content_library_approved_byTousers", fields: [approved_by], references: [id])
  creator                                       users?   @relation("team_content_library_created_byTousers", fields: [created_by], references: [id])
  team                                          teams    @relation(fields: [team_id], references: [id], onDelete: Cascade)
}

model team_members {
  id         String    @id @default(uuid())
  team_id    String
  user_id    String
  role       String    @default("member")
  invited_at DateTime  @default(now())
  joined_at  DateTime?
  status     String    @default("pending")
  team       teams     @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user       users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([team_id, user_id])
}

model team_style_guides {
  id              String   @id @default(uuid())
  team_id         String
  brand_voice     String?
  tone            String?
  approved_terms  Json     @default("[]")
  forbidden_terms Json     @default("[]")
  custom_rules    Json     @default("{}")
  updated_by      String?
  updated_at      DateTime @default(now())
  teams           teams    @relation(fields: [team_id], references: [id], onDelete: Cascade)
  updater         users?   @relation(fields: [updated_by], references: [id])
}

model teams {
  id                   String                 @id @default(uuid())
  name                 String
  owner_id             String
  subscription_tier    String                 @default("teams")
  max_members          Int                    @default(50)
  created_at           DateTime               @default(now())
  updated_at           DateTime               @default(now())
  team_content_library team_content_library[]
  team_members         team_members[]
  team_style_guides    team_style_guides[]
  owner                users                  @relation(fields: [owner_id], references: [id], onDelete: Cascade)
}

model transactions {
  id                  String     @id @default(uuid())
  user_id             String
  action              String
  coins_used          Int
  details             Json?      @default("{}")
  related_document_id String?
  created_at          DateTime   @default(now())
  documents           documents? @relation(fields: [related_document_id], references: [id])
  users               users      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model user_profiles {
  id                       String               @id
  coins_balance            Int                  @default(100)
  total_ai_requests        Int                  @default(0)
  words_processed          Int                  @default(0)
  daily_streak             Int                  @default(0)
  last_login_date          DateTime?            @db.Date
  subscription_tier        String               @default("free")
  razorpay_subscription_id String?
  created_at               DateTime             @default(now())
  updated_at               DateTime             @default(now())
  referral_code            String?              @unique
  referred_by              String?
  total_referrals          Int                  @default(0)
  ai_usage_analytics       ai_usage_analytics[]
  coins_transactions       coins_transactions[]
  users                    users                @relation(fields: [id], references: [id], onDelete: Cascade)
}

model users {
  id                                                           String                 @id @default(uuid())
  email                                                        String                 @unique
  full_name                                                    String?
  avatar_url                                                   String?
  subscription_tier                                            String                 @default("free")
  coin_balance                                                 Int                    @default(100)
  onboarding_completed                                         Boolean                @default(false)
  preferences                                                  Json                   @default("{}")
  created_at                                                   DateTime               @default(now())
  updated_at                                                   DateTime               @default(now())
  emailVerified                                                DateTime?
  password                                                     String?
  accounts                                                     accounts[]
  analytics                                                    analytics[]
  audit_logs                                                   audit_logs[]
  documents                                                    documents[]
  plagiarism_checks                                            plagiarism_checks[]
  revisions                                                    revisions[]
  sessions                                                     sessions[]
  subscriptions                                                subscriptions?
  team_content_library_team_content_library_approved_byTousers team_content_library[] @relation("team_content_library_approved_byTousers")
  team_content_library_team_content_library_created_byTousers  team_content_library[] @relation("team_content_library_created_byTousers")
  team_members                                                 team_members[]
  team_style_guides                                            team_style_guides[]
  teams                                                        teams[]
  transactions                                                 transactions[]
  notifications                                                notifications[]
  user_profiles                                                user_profiles?
}

model verification_tokens {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model password_reset_tokens {
  id         String   @id @default(uuid())
  email      String
  token      String   @unique
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())

  @@index([email])
  @@index([token])
}
