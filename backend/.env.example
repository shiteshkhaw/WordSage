# WORDSAGE BACKEND - ENVIRONMENT VARIABLES
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/DATABASE?sslmode=require

# Authentication (must match frontend)
NEXTAUTH_SECRET=YOUR_SECRET_HERE

# AI Services
OPENROUTER_API_KEY=YOUR_API_KEY

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# CORS
FRONTEND_URL=http://YOUR_EC2_IP:3000
CORS_ORIGIN=http://YOUR_EC2_IP:3000

# Server
PORT=4000
NODE_ENV=production
