# ============================================================
# WordSage Backend - Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git - only this .env.example file.
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/wordsage?sslmode=require"

# --- Server ---
PORT=4000
NODE_ENV=production

# --- Auth (must match frontend NEXTAUTH_SECRET exactly) ---
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=https://your-domain.com

# --- CORS ---
FRONTEND_URL=https://your-domain.com
CORS_ORIGIN=https://your-domain.com

# --- AI ---
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_PRO_PLAN_ID=plan_xxxxxxxxxxxxxxxx
RAZORPAY_TEAM_PLAN_ID=plan_xxxxxxxxxxxxxxxx

# --- Google OAuth ---
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# --- AWS (optional, for file/avatar storage) ---
AWS_REGION=ap-south-1
